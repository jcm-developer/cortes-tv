# API key de TheMovieDB (v3 auth, solo lectura).
# Consíguela en https://www.themoviedb.org/settings/api
# En un sitio estático esta clave queda EXPUESTA en el cliente; usa una
# clave de solo lectura.
PUBLIC_TMDB_API_KEY=tu_api_key_de_tmdb

# (Opcional) Idioma y región por defecto para las peticiones a TMDB.
PUBLIC_TMDB_LANG=es-ES
PUBLIC_TMDB_REGION=ES

# Login de un solo usuario (lo defines tú). Si dejas ambos vacíos, el acceso
# es abierto (sin login). En un sitio estático estas credenciales viajan en el
# bundle del cliente: NO es seguridad real, solo "cerrar la puerta".
PUBLIC_AUTH_USER=admin
PUBLIC_AUTH_PASSWORD=cambia-esto
