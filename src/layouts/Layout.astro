---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Cortes TV' } = Astro.props;
const base = import.meta.env.BASE_URL;
const withBase = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="Gestiona tus películas y series con un diseño Apple, Liquid Glass." />
    <meta name="theme-color" content="#f5f5f5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#121212" media="(prefers-color-scheme: dark)" />

    <!-- PWA / Añadir a inicio en iOS -->
    <link rel="manifest" href={withBase('manifest.webmanifest')} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Cortes TV" />
    <link rel="apple-touch-icon" href={withBase('logo.png')} />
    <link rel="icon" type="image/png" href={withBase('logo.png')} />

    <title>{title}</title>

    <!-- Tema sin flash: aplica .dark antes del primer pintado -->
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem('cortes-tv:theme') || 'system';
          const dark =
            t === 'dark' ||
            (t === 'system' && matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.classList.toggle('dark', dark);
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <!-- Fondo atmosférico: blobs de color difuminados para que refracte el vidrio -->
    <div class="fixed inset-0 -z-10 overflow-hidden bg-neutral-100 dark:bg-neutral-950" aria-hidden="true">
      <div class="absolute -top-32 -left-24 h-[26rem] w-[26rem] rounded-full bg-blue-400/35 dark:bg-blue-500/20 blur-3xl"></div>
      <div class="absolute top-1/3 -right-20 h-[24rem] w-[24rem] rounded-full bg-indigo-400/30 dark:bg-indigo-500/18 blur-3xl"></div>
      <div class="absolute -bottom-24 left-1/4 h-[28rem] w-[28rem] rounded-full bg-pink-400/25 dark:bg-fuchsia-500/15 blur-3xl"></div>
      <div class="absolute top-10 left-1/2 h-72 w-72 rounded-full bg-teal-300/25 dark:bg-teal-500/12 blur-3xl"></div>
    </div>

    <slot />
  </body>
</html>
